        <mxCell id="s5a7" value="setWorldData + seedStatus&#xa;hydrate(history) → 恢復聊天&#xa;播放 yolo_video / raw_video" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
