        <mxCell id="s3_note_p2" value="detect_events → contacts + bounces&#xa;segment_rallies + build_single_rally&#xa;compute_frame_speeds_world (km/h)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
