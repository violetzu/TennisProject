        <mxCell id="s4_note_think" value="thinking=True: 緩衝直到 &lt;/think&gt;&#xa;thinking=False: yield token 到前端" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="720" y="2075" width="200" height="35" as="geometry" />
