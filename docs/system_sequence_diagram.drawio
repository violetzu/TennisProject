        <!-- ================================================================ -->
        <!-- SECTION 4: AI 聊天流程 (Chat Flow) -->
        <!-- ================================================================ -->
        <mxCell id="s4_frame" value="&lt;b&gt;4. AI 聊天流程 (Chat with Streaming)&lt;/b&gt;" style="shape=umlFrame;whiteSpace=wrap;html=1;width=300;height=20;fillColor=#f0f0f0;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="30" y="1790" width="1580" height="490" as="geometry" />
