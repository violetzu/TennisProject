        <!-- SSE streaming loop -->
        <mxCell id="s4_loop_sse" value="loop [SSE stream tokens]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=170;height=18;fillColor=none;strokeColor=#666666;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="2040" width="1300" height="130" as="geometry" />
        </mxCell>

        <mxCell id="s4a5" value="SSE delta token" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
