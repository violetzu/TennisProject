        </mxCell>

        <!-- Phase 4: Aggregate -->
        <mxCell id="s3_phase4" value="&lt;b&gt;階段 4: 統計彙整&lt;/b&gt;" style="shape=umlFrame;whiteSpace=wrap;html=1;width=230;height=18;fillColor=none;strokeColor=#9673a6;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1490" width="460" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s3_note_p4" value="build_summary() → analysis.json" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1512" width="230" height="25" as="geometry" />
        </mxCell>

        <!-- Analysis complete → update DB -->
        <mxCell id="s3a_done1" value="UPDATE analysis_records&#xa;SET analysis_json_path, yolo_video_path" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1240" y="1565" as="sourcePoint" />
            <mxPoint x="960" y="1565" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="s3a_done2" value="sess[&quot;status&quot;] = &quot;completed&quot;" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1240" y="1590" as="sourcePoint" />
            <mxPoint x="680" y="1590" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Frontend receives completed -->
        <mxCell id="s3a8" value="status=completed&#xa;→ onCompleted(&quot;combine&quot;)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="1625" as="sourcePoint" />
            <mxPoint x="400" y="1625" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="s3a9" value="POST /api/analysisrecord&#xa;{analysis_record_id, guest_token?}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="1660" as="sourcePoint" />
            <mxPoint x="680" y="1660" as="targetPoint" />
