        <mxCell id="s7_note" value="1. 清除 _chunks/ 下 &gt;1hr 暫存&#xa;2. 清除 guest/ 下 &gt;7天 影片&#xa;3. DELETE DB 訪客 records &gt;7天" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
