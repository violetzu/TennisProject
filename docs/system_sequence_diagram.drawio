        <mxCell id="s3a11" value="setWorldData → 顯示分析結果&#xa;播放標注影片" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
