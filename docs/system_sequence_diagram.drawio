        <mxCell id="s6_frame" value="&lt;b&gt;6. 重新分析流程 (Reanalyze)&lt;/b&gt;" style="shape=umlFrame;whiteSpace=wrap;html=1;width=260;height=20;fillColor=#f0f0f0;strokeColor=#999999;" vertex="1" parent="1">
