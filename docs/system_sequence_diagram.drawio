        </mxCell>
        <mxCell id="s4a2" value="POST /api/chat（SSE proxy）&#xa;{session_id, question}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="400" y="1875" as="sourcePoint" />
