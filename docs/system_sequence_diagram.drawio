        <mxCell id="s3_vlm2" value="&lt;winner&gt;top|bottom|unknown&lt;/winner&gt;" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
