        </mxCell>
        <mxCell id="s3a10" value="{record, world_data, history}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="1685" as="sourcePoint" />
            <mxPoint x="400" y="1685" as="targetPoint" />
