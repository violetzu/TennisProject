            <mxPoint x="680" y="1260" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Phase 2: Events -->
        <mxCell id="s3_phase2" value="&lt;b&gt;階段 2: 事件偵測 + 回合整理&lt;/b&gt;" style="shape=umlFrame;whiteSpace=wrap;html=1;width=260;height=18;fillColor=none;strokeColor=#9673a6;strokeWidth=1;" vertex="1" parent="1">
