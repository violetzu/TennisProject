        <!-- Phase 1: Detection -->
        <mxCell id="s3_phase1" value="&lt;b&gt;階段 1: 逐幀偵測與標注輸出&lt;/b&gt;" style="shape=umlFrame;whiteSpace=wrap;html=1;width=220;height=18;fillColor=none;strokeColor=#9673a6;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="1060" width="460" height="200" as="geometry" />
        </mxCell>
        <mxCell id="s3_note_p1" value="FFmpeg decode → 逐幀 numpy&#xa;&#xa;1. 場地偵測 (court_model, conf≥0.8)&#xa;   → Homography + 14 關鍵點&#xa;   → draw_court()&#xa;&#xa;2. Pose 偵測 (yolo26s-pose)&#xa;   → 上/下方球員位置 + 手腕座標&#xa;   → draw_skeleton()&#xa;&#xa;3. Ball 偵測 (BallTracker)&#xa;   → 靜止黑名單 + 離群過濾&#xa;&#xa;4. 滑動窗口 process_window()&#xa;   → 插值 → 定案&#xa;&#xa;5. 回合感知繪製 → FFmpeg encode" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1085" width="230" height="170" as="geometry" />
        </mxCell>

        <mxCell id="s3_prog1" value="progress_cb(done, total)&#xa;→ sess[&quot;progress&quot;] 0-95%" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;fontSize=10;" edge="1" parent="1">
