        <mxCell id="s3_vlm1" value="verify_rally_winner()&#xa;縮圖 → VLM 推理" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
