# Cloudflare Tunnel
CF_TUNNEL_TOKEN=
ALLOWED_DEV_ORIGINS=your-domain.example.com   # Tunnel HMR WebSocket 用

# PostgreSQL（user / db hardcode 為 tennis，只有密碼放 env）
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD   # openssl rand -base64 32

# Backend JWT 密鑰
SECRET_KEY=CHANGE_ME_SECRET_KEY   # openssl rand -base64 32

# VLLM（本地推理，不用時留空）
APP_VLLM_URL=http://vllm:8005
APP_VLLM_MODEL=Qwen/Qwen3.5-27B-FP8
APP_VLLM_API_KEY=

# Embedding（本地推理，不用時留空）
APP_EMBEDDING_URL=http://vllm-embedding:8006
APP_EMBEDDING_MODEL=BAAI/bge-m3
APP_EMBEDDING_API_KEY=

# 後端給 vLLM 的影片 URL domain
VIDEO_URL_DOMAIN=http://backend:8000
